# AI 视频总结：复制为 backend/.env 后填写真实密钥（勿提交 .env）

# 方案 A：DeepSeek 官方
# AI_API_KEY=sk-xxx
# AI_BASE_URL=https://api.deepseek.com
# AI_MODEL=deepseek-chat

# 方案 B：火山引擎方舟（OpenAI 兼容，endpoint 一般为 .../api/v3）
AI_API_KEY=your-ark-api-key
AI_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
AI_MODEL=your-endpoint-model-id

# ---------- 用户认证（JWT）----------
# 生产环境请改为足够长的随机字符串（至少 32 字符）
JWT_SECRET=change-me-to-a-long-random-secret-at-least-32-chars
JWT_EXPIRE_MINUTES=10080

# ---------- Stripe 一次性买断 VIP（人民币 CNY）----------
# Test mode 密钥：https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_xxx
# 在 Stripe Dashboard 创建「一次性」Price（Currency: CNY）后填入
STRIPE_PRICE_ID=price_xxx
# 本地开发：stripe listen --forward-to localhost:8000/api/stripe/webhook 输出的 whsec_
# 生产环境：Dashboard → Webhooks → 添加 endpoint 后获得
STRIPE_WEBHOOK_SECRET=whsec_xxx

# 前端地址（支付成功/取消回跳；生产改为 https://your-domain.com）
FRONTEND_ORIGIN=http://localhost:5173
